PYMS_APP_ENV=production
PYMS_HOST=0.0.0.0
PYMS_PORT=8000
PYMS_API_KEY=
PYMS_AUTH_ENABLED=true
PYMS_SESSION_TTL_HOURS=24
PYMS_DB_URL=postgresql://pyms:pyms@postgres:5432/pyms
PYMS_REDIS_URL=redis://redis:6379/0
PYMS_QUEUE_BACKEND=celery
PYMS_QUEUE_BATCH_SIZE=20
PYMS_QUEUE_POLL_INTERVAL_SECONDS=2
PYMS_QUEUE_PAGE_SIZE=20
PYMS_QUEUE_PAGE_SIZE_MAX=200
PYMS_RESULT_PAGE_SIZE=20
PYMS_RESULT_PAGE_SIZE_MAX=200

POSTGRES_DB=pyms
POSTGRES_USER=pyms
POSTGRES_PASSWORD=replace-with-strong-password
